services:
  cram-api:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: cram-api
    ports:
      - "2727:8003"
    environment:
      - OLLAMA_BASE_URL=http://host.docker.internal:11435
    extra_hosts:
      - "host.docker.internal:host-gateway"
    restart: always
    depends_on:
      - ollama-check

  ollama-check:
    image: curlimages/curl:latest
    command: ["sh", "-c", "curl http://host.docker.internal:11435/api/tags"]
    restart: "no"