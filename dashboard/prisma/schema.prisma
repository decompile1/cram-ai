generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model User {
    id        String     @id @default(cuid())
    email     String     @unique
    password  String
    name      String?
    createdAt DateTime   @default(now())
    StudySets StudySet[]
}

model StudySet {
    id        String   @id @default(cuid())
    title     String   
    course    String   
    cards     Json     // Stores your AI generated flashcard array
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    createdAt DateTime @default(now())
}