generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  name      String?
  createdAt DateTime   @default(now())
  studySets StudySet[]
}

model StudySet {
  id          String    @id @default(cuid())
  title       String
  studyGoal   String?
  outputType  String?
  difficulty  String?
  examDate    DateTime?
  cards       Json
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
}